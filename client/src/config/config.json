    "showAboutPage": true,
    "about": {
      "logos": [
        "/assets/logos/about1.svg",
        "/assets/logos/about2.svg",
        "/assets/logos/about3.svg"
      ],
      "descriptions": [
        "The <b>European Genome-phenome Archive (EGA)</b> is a global network for permanent archiving and sharing of personally identifiable genetic, phenotypic, and clinical data generated by biomedical research projects or in the context of research-focused healthcare systems. With expertise in data management and technical infrastructure, EGA promotes FAIR data reuse and enables researchers to share their data securely. The EGA is jointly managed by the <b>European Bioinformatics Institute (EMBL-EBI)</b> in Cambridge (UK) and the <b>Centre for Genomic Regulation (CRG)</b> in Barcelona, and provides a free service for permanent data storage, data discovery, and secure data access.",
        "The EGA is part of the ELIXIR Infrastructure and one of the <b>ELIXIR Core Data Resources</b>, a collection of data resources considered of fundamental importance to the wider life-science community and the long-term preservation of biological data. Additionally, the EGA has played a central role in driving the development of the Beacon data discovery tool and coordinating its implementation by ELIXIR Nodes."
      ],
      "fundingOrgs": [
        {
          "title": "Funding Organizations",
          "logos": [
            "/assets/logos/organization1.svg",
            "/assets/logos/organization2.svg",
            "/assets/logos/organization3.svg",
            "/assets/logos/organization4.svg"
          ]
        }
      ]
    },

    "showLogin": true,
    "disableLogin": true,
    "demoMode": true,
    "auth": {
      "providerType": "public",
      "oidc": {
        "authority": "https://login.aai.lifescience-ri.eu/oidc",
        "autoSignIn": false,
        "responseType": "code",
        "automaticSilentRenew": true,
        "redirectUri": "http://localhost:3000/",
        "scope": "openid profile email ga4gh_passport_v1 offline_access",
        "revokeAccessTokenOnSignout": true
